{
  "name": "vscode-pdf-docs",
  "displayName": "vscode-pdf-docs",
  "description": "A PDF viewer for VS Code with linkable document sections",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "VSCode PDF Docs",
      "properties": {
        "vscode-pdf-docs.darkMode": {
          "type": "string",
          "enum": [
            "off",
            "on",
            "auto"
          ],
          "enumDescriptions": [
            "Always use light PDF rendering.",
            "Always use dark PDF rendering.",
            "Follow the active VS Code color theme."
          ],
          "default": "auto",
          "description": "Controls PDF reading dark mode for the custom PDF preview."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "pdfOutlineExplorer",
          "name": "PDF Outline",
          "when": "activeCustomEditorId == vscode-pdf-docs.pdfPreview"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-pdf-docs.goToPage",
        "title": "PDF: Go to Page"
      },
      {
        "command": "vscode-pdf-docs.showOutline",
        "title": "PDF: Show Outline"
      },
      {
        "command": "vscode-pdf-docs.toggleDarkMode",
        "title": "PDF: Toggle Dark Mode"
      },
      {
        "command": "vscode-pdf-docs.refreshOutline",
        "title": "PDF: Refresh Outline"
      },
      {
        "command": "vscode-pdf-docs.revealOutlinePage",
        "title": "PDF: Reveal Outline Page"
      },
      {
        "command": "vscode-pdf-docs.openPdfCommentReference",
        "title": "PDF: Open Comment Reference"
      },
      {
        "command": "vscode-pdf-docs.copyOutlineSectionName",
        "title": "Copy Section Name"
      },
      {
        "command": "vscode-pdf-docs.copyOutlineFullPath",
        "title": "Copy Full Section Name"
      },
      {
        "command": "vscode-pdf-docs.copyOutlineSectionPath",
        "title": "Copy Section Path"
      },
      {
        "command": "vscode-pdf-docs.copyOutlineFullSectionPath",
        "title": "Copy Full Section Path"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "vscode-pdf-docs.revealOutlinePage",
          "when": "false"
        },
        {
          "command": "vscode-pdf-docs.openPdfCommentReference",
          "when": "false"
        },
        {
          "command": "vscode-pdf-docs.copyOutlineSectionName",
          "when": "false"
        },
        {
          "command": "vscode-pdf-docs.copyOutlineFullPath",
          "when": "false"
        },
        {
          "command": "vscode-pdf-docs.copyOutlineSectionPath",
          "when": "false"
        },
        {
          "command": "vscode-pdf-docs.copyOutlineFullSectionPath",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "vscode-pdf-docs.copyOutlineSectionName",
          "when": "view == pdfOutlineExplorer && viewItem == pdfOutlineItem",
          "group": "copy@1"
        },
        {
          "command": "vscode-pdf-docs.copyOutlineFullPath",
          "when": "view == pdfOutlineExplorer && viewItem == pdfOutlineItem",
          "group": "copy@2"
        },
        {
          "command": "vscode-pdf-docs.copyOutlineSectionPath",
          "when": "view == pdfOutlineExplorer && viewItem == pdfOutlineItem",
          "group": "copy@3"
        },
        {
          "command": "vscode-pdf-docs.copyOutlineFullSectionPath",
          "when": "view == pdfOutlineExplorer && viewItem == pdfOutlineItem",
          "group": "copy@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vscode-pdf-docs.goToPage",
        "key": "alt+g",
        "when": "activeCustomEditorId == vscode-pdf-docs.pdfPreview"
      },
      {
        "command": "vscode-pdf-docs.showOutline",
        "key": "ctrl+shift+o",
        "when": "activeCustomEditorId == vscode-pdf-docs.pdfPreview"
      }
    ],
    "customEditors": [
      {
        "viewType": "vscode-pdf-docs.pdfPreview",
        "displayName": "PDF Preview",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@types/vscode": "^1.115.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
